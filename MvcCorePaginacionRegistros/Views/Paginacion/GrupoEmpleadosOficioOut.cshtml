@{
}
@model List<Empleado>

<h1 style="color:forestgreen"> Paginar Grupo Empleados Oficio OUT</h1>

<form method="post">
    <label>Introduzca oficio:</label>
    <input type="text" name="oficio" class="form-control" />
    <button class="btn btn-warning">Filtrar</button>
</form>

@{
    int numRegistros = 0;
    int numPagina = 1;
    string oficio = "";
    if (ViewData["NUMREGISTROS"] != null)
    {
        numRegistros = (int)ViewData["NUMREGISTROS"];
        oficio = ViewData["OFICIO"].ToString();
    }
}

@if (Model != null)
{
    <h1>Numero: @numRegistros</h1>
    <div>
        @for (int i = 1; i <= numRegistros; i += 3)
        {
            <a asp-controller="Paginacion" asp-action="GrupoEmpleadosOficioOut"
               asp-route-posicion="@i" class="btn btn-danger" asp-route-oficio="@oficio">
                Pagina @numPagina
            </a>
            numPagina += 1;
        }

    </div>
    <table class="table table-info table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Apellidos</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Departamento</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Empleado emp in Model)
            {
                <tr>
                    <td>@emp.IdEmpleado</td>
                    <td>@emp.Apellido</td>
                    <td>@emp.Oficio</td>
                    <td>@emp.Salario</td>
                    <td>@emp.IdDepartamento</td>
                </tr>
            }
        </tbody>
    </table>
}
